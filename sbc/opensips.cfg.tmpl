####### Global Parameters ########

log_level=3
xlog_level=3
stderror_enabled=no
syslog_enabled=yes
syslog_facility=LOG_LOCAL0

udp_workers=4

socket=udp:${SBC_IP}:5060

####### Modules Section ########

mpath="/usr/lib/x86_64-linux-gnu/opensips/modules/"

loadmodule "proto_udp.so"

loadmodule "signaling.so"
loadmodule "sl.so"
loadmodule "tm.so"
loadmodule "rr.so"
loadmodule "maxfwd.so"
loadmodule "sipmsgops.so"
loadmodule "textops.so"
loadmodule "path.so"

loadmodule "rtpengine.so"
modparam("rtpengine", "rtpengine_sock", "udp:127.0.0.1:2223")

loadmodule "mi_fifo.so"
modparam("mi_fifo", "fifo_name", "/run/opensips/opensips_fifo")
modparam("mi_fifo", "fifo_mode", 0666)

####### Routing Logic ########

route {
    # 1) Max-Forwards sanity
    if (!mf_process_maxfwd_header(10)) {
        sl_send_reply(483, "Too Many Hops");
        exit;
    }

    # 2) In-dialog requests (carry a to-tag) or requests with a Route header
    #    set by an earlier Record-Route. loose_route() consumes the top Route
    #    and updates $du if present.
    if (loose_route()) {
        if (is_method("BYE")) {
            rtpengine_delete();
        } else if (is_method("INVITE")) {
            record_route();
            rtpengine_offer();
        }
        t_relay();
        exit;
    }

    # 3) Initial REGISTER — add Path so Asterisk routes return traffic
    #    back through this SBC, then relay upstream to Asterisk.
    #    baresip does not advertise "Supported: path"; per RFC 3327 a
    #    registrar must reject Path-bearing REGISTERs from clients that
    #    did not advertise support. We inject Supported: path on the
    #    client's behalf so Asterisk accepts the Path header we added.
    if (is_method("REGISTER")) {
        append_hf("Supported: path\r\n");
        add_path_received();
        $du = "sip:${ASTERISK_IP}:5060";
        t_relay();
        exit;
    }

    # 4) Initial INVITE — pin the dialog to this SBC via Record-Route,
    #    rewrite SDP through rtpengine, then relay upstream to Asterisk.
    if (is_method("INVITE")) {
        record_route();
        rtpengine_offer();
        $du = "sip:${ASTERISK_IP}:5060";
        t_relay();
        exit;
    }

    # 5) Anything else (OPTIONS, etc.) — pass-through.
    t_relay();
}

onreply_route {
    # rtpengine_answer() must only run on responses that BELONG TO AN INVITE
    # transaction AND carry an SDP body. Two non-obvious traps that pollute
    # syslog if either condition is dropped:
    #   - 200 OK on REGISTER / BYE has no body          → "can't extract body"
    #   - 200 OK on Asterisk's qualify OPTIONS to the softphone CAN carry
    #     an SDP body (baresip advertises capability that way), so the body
    #     check alone is not enough; rtpengine has no offer for that call-id
    #                                                  → "Unknown call-id"
    # In onreply_route is_method() matches against the CSeq method, which is
    # the original request's method, so this correctly filters non-INVITE.
    if (is_method("INVITE")
        && ($rs == 180 || $rs == 183 || $rs == 200)
        && has_body("application/sdp")) {
        rtpengine_answer();
    }
}
