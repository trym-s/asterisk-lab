# Space-separated list of SIP endpoint numbers to provision. For each entry
# here, install.sh expects a matching SIP_EXT_<num>_PASSWORD below and renders
# /etc/asterisk/pjsip.d/<num>.conf from asterisk/pjsip-endpoint.conf.tmpl.
# Add a new extension: append the number here, add its password below, re-run.
SIP_EXTENSIONS="1001 1002"

# SIP auth passwords (one per entry in SIP_EXTENSIONS). Baresip must present
# the matching value as auth_pass.
SIP_EXT_1001_PASSWORD=
SIP_EXT_1002_PASSWORD=

# Asterisk source tag to build. Pinned for reproducibility — bumping this
# rebuilds the daemon at install time.
ASTERISK_VERSION=22.9.0

# --- FreePBX inbound trunk (Asterisk VM only) --------------------------
#
# Public host/IP of the remote FreePBX. Setting FREEPBX_HOST ENABLES the
# trunk: install.sh renders /etc/asterisk/pjsip.trunks.d/freepbx.conf from
# asterisk/pjsip-trunk.conf.tmpl. Leave empty to disable -- re-running
# install.sh then removes the rendered file.
#
# This VM is behind libvirt NAT behind WSL2 NAT behind the ISP router, so
# FreePBX cannot reach it inbound. We register OUTBOUND as an ordinary
# extension; FreePBX's Inbound Route sends the DID to that extension and the
# call comes down the registered line to [from-freepbx] -> [voicebot].
# See docs/runbooks/freepbx-trunk.md.
FREEPBX_HOST=
# FreePBX SIP port. Often NOT 5060 on a public box (scanner avoidance).
FREEPBX_PORT=5060
# The extension provisioned for this lab on FreePBX, and its secret.
# Required whenever FREEPBX_HOST is set.
FREEPBX_EXT=
FREEPBX_EXT_PASSWORD=
# Dialplan context inbound DID calls land in. Must exist in extensions.conf.
FREEPBX_CONTEXT=from-freepbx

# --- SBC layer (only needed on the OpenSIPS SBC VM) --------------------

# SBC VM's own IP — used by sbc/install.sh to render opensips.cfg
# (socket=udp:$SBC_IP:5060). OpenSIPS uses this address in the Via,
# Record-Route and Path headers it inserts, so it must match what
# `ip -4 addr` reports inside the SBC VM, not a guess. Read it from
# `virsh net-dhcp-leases default` after first boot of the SBC VM.
SBC_IP=

# Asterisk VM IP — used by sbc/install.sh to render the relay target
# ($du = "sip:$ASTERISK_IP:5060") inside opensips.cfg. Read it from
# `virsh net-dhcp-leases default` after first boot of the Asterisk VM.
ASTERISK_IP=

# --- Monitoring layer --------------------------------------------------

# Monitoring VM IP. Used by zabbix-agent2 on monitored nodes and by the
# monitoring VM's local agent. Read from `virsh net-dhcp-leases default`
# after the monitoring VM boots; DHCP allocations are not fixed.
MONITORING_IP=

# Zabbix server database password. Required only on the monitoring VM.
# Keep the real value in .env on that VM; deploy excludes .env.
ZABBIX_DB_PASSWORD=

# Zabbix major version used by monitoring/install.sh and agent setup.
ZABBIX_VERSION=7.0

# --- Host-side VM access ------------------------------------------------

# Host sudo password, used for host-scoped commands that need root (e.g.
# `sudo virsh net-dhcp-leases default` to look up VM IPs).
SUDO_PASS=

# SSH password for the `deb` user on every VM. VM IPs are DHCP-allocated;
# look them up with `sudo virsh net-dhcp-leases default` first, then
# `ssh deb@<ip>`.
SSH_PASS=

# --- Voicebot stack (Asterisk VM only) ---------------------------------

# OpenAI API key used by the Pipecat agent's LLM (gpt-4o-mini by default).
OPENAI_API_KEY=

# Soniox API key used by the Pipecat agent for streaming STT (stt-rt-v5)
# and streaming TTS. Get one at https://console.soniox.com.
SONIOX_API_KEY=

# Optional profile overrides. Defaults (see services/common/voicebot_profile.py):
# soniox stt-rt-v5 (STT), openai gpt-4o-mini (LLM), soniox tts-rt-v1 (TTS),
# voice Adrian. Set on the Asterisk VM before deploying to change a run.

# Label only: recorded with each run so a result can be traced back to the
# models that produced it. It selects nothing -- the VOICEBOT_*_MODEL vars
# below do that. Renaming this changes no behaviour.
VOICEBOT_MODEL_PROFILE=
VOICEBOT_STT_MODEL=
VOICEBOT_LLM_MODEL=
VOICEBOT_TTS_MODEL=
VOICEBOT_TTS_VOICE=

# Optional Soniox endpoint-detection tuning (turn-end feel). Sensitivity is
# -1.0..1.0 (higher ends turns sooner); max delay is 500-3000 ms.
VOICEBOT_STT_ENDPOINT_SENSITIVITY=
VOICEBOT_STT_MAX_ENDPOINT_DELAY_MS=

# Bot-echo transcript filter (host softphone speaker loopback guard).
# Enabled by default; set 0 to bypass.
VOICEBOT_ECHO_FILTER=

# Optional run id grouping key. Set on the Asterisk VM before running
# run-suite.sh so the run's call.started/profile.loaded events carry the
# same run_id and the dashboard can scope to that run. Leave unset for
# ordinary traffic.
VOICEBOT_RUN_ID=

# Voicebot observability dashboard (Asterisk VM only). Binds loopback by
# default; reach it over an SSH tunnel. 8090 (AudioSocket) and 4444
# (baresip ctrl_tcp) are already taken on this VM.
VOICEBOT_DASHBOARD_BIND=127.0.0.1
VOICEBOT_DASHBOARD_PORT=8099
VOICEBOT_DASHBOARD_REFRESH_S=5
VOICEBOT_DASHBOARD_DEFAULT_RANGE=1h
VOICEBOT_DASHBOARD_COST_BUCKET=1h
VOICEBOT_DASHBOARD_ACTIVE_CALL_STALE_S=120
VOICEBOT_DASHBOARD_ASTERISK_CLI=asterisk
VOICEBOT_DASHBOARD_ZABBIX_API_URL=
VOICEBOT_DASHBOARD_ZABBIX_API_TOKEN=

# Comparison view (historical multi-lane data). Minimum sample count before
# a per-stage p95 renders (below it only p50+N show); path to the read-only
# expected-answer fixture used by the Paired Quality panel.
VOICEBOT_DASHBOARD_LATENCY_MIN_N=20
VOICEBOT_DASHBOARD_EXPECTED_CORPUS_PATH=

# Optional basic-auth toggle for the dashboard. Leave both empty to disable
# (default); the service has no other authentication in v1.
VOICEBOT_DASHBOARD_BASIC_AUTH_USER=
VOICEBOT_DASHBOARD_BASIC_AUTH_PASSWORD=

# ElevenLabs — used only by services/test-caller/gen-utterances.sh to
# synthesize the fixed test corpus. Voice ID is per-voice (find one at
# https://elevenlabs.io/app/voice-library — pick a Turkish-capable voice).
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
# Optional; defaults to eleven_flash_v2_5 (cheapest, low-latency).
# Alternatives: eleven_turbo_v2_5 (mid), eleven_multilingual_v2 (best fidelity).
ELEVENLABS_MODEL_ID=
