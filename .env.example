# SIP auth password for extension 1001. Used by Asterisk's PJSIP digest
# authentication. The softphone (any SIP client — baresip, Linphone, MicroSIP,
# Zoiper, ...) must present the same value.
SIP_EXT_1001_PASSWORD=

# Asterisk source tag to build. Pinned for reproducibility — bumping this
# rebuilds the daemon at install time.
ASTERISK_VERSION=22.9.0
