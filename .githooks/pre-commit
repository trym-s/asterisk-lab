#!/bin/bash
# Pre-commit checks:
#   1. Identity: commits must carry a configured git identity.
#   2. Character conventions (harness paths only): em/en dashes, non-ASCII
#      arrows, emoji, typographic quotes, and other non-ASCII punctuation are
#      banned in the English AI context/workflow files (see AGENTS.md,
#      Working Rules). Application source and user-facing content are NOT
#      checked; non-English product text keeps its proper native characters.
#
# Agents must set their identity before committing:
#   Codex:  git config user.name "Codex"  && git config user.email "codex@asterisk-lab.local"
#   Claude: git config user.name "Claude" && git config user.email "claude@asterisk-lab.local"
#
# Harness paths that legitimately need non-ASCII content can be listed in
# .githooks/ascii-allowlist, one path prefix per line.

name=$(git config user.name)
email=$(git config user.email)

if [ -z "$name" ] || [ -z "$email" ]; then
  echo "ERROR: git user.name and user.email must be configured before committing."
  echo ""
  echo "  Codex:  git config user.name 'Codex'  && git config user.email 'codex@asterisk-lab.local'"
  echo "  Claude: git config user.name 'Claude' && git config user.email 'claude@asterisk-lab.local'"
  echo "  Human:  git config user.name 'Your Name' && git config user.email 'you@example.com'"
  exit 1
fi

# Only these paths are subject to the ASCII character conventions.
is_harness_path() {
  case "$1" in
    docs/*|.claude/*|.codex/*|.agents/*|.githooks/*) return 0 ;;
    *.md) case "$1" in */*) return 1 ;; *) return 0 ;; esac ;;  # root-level .md files
    *) return 1 ;;
  esac
}

allowlist=".githooks/ascii-allowlist"
fail=0

while IFS= read -r file; do
  [ -f "$file" ] || continue
  is_harness_path "$file" || continue
  # skip binary files
  git diff --cached --numstat -- "$file" | grep -q '^-' && continue
  # skip allowlisted path prefixes
  if [ -f "$allowlist" ]; then
    skip=0
    while IFS= read -r prefix; do
      [ -n "$prefix" ] || continue
      case "$file" in "$prefix"*) skip=1; break ;; esac
    done < "$allowlist"
    [ "$skip" = "1" ] && continue
  fi
  # banned in harness files: any non-ASCII character (covers em/en dashes,
  # arrows, emoji, typographic quotes, and other non-ASCII punctuation)
  hits=$(git show ":$file" | LC_ALL=C grep -nP '[^\x00-\x7F]' | head -5)
  if [ -n "$hits" ]; then
    echo "ERROR: banned non-ASCII characters in staged harness file: $file"
    echo "$hits" | head -5
    fail=1
  fi
done < <(git diff --cached --name-only --diff-filter=ACMR)

# 3. Spec naming boundary (AGENTS.md hard rule): specNN tokens may appear only
#    in docs/ and harness files - never in application code, configs, service
#    names, or paths. Lines that merely link to docs/specs|docs/prompts pass.
while IFS= read -r file; do
  [ -f "$file" ] || continue
  is_harness_path "$file" && continue
  case "$file" in docs/*) continue ;; esac
  git diff --cached --numstat -- "$file" | grep -q '^-' && continue
  hits=$(git show ":$file" | grep -nEi '\bspec[0-9]{2,3}\b' | grep -vE 'docs/(specs|prompts)/' | head -5)
  if [ -n "$hits" ]; then
    echo "ERROR: spec number token leaked into application path: $file"
    echo "$hits" | head -5
    echo "Spec tokens belong in docs/, root workflow files, and harness dirs only."
    fail=1
  fi
done < <(git diff --cached --name-only --diff-filter=ACMR)

if [ "$fail" = "1" ]; then
  echo ""
  echo "AI context/workflow files are English ASCII: use '-' or '--' for dashes,"
  echo "'->' or '=>' for arrows, straight quotes, and no emoji (AGENTS.md rules)."
  echo "This check does not apply to application source or user-facing content."
  echo "Harness-path exceptions go into .githooks/ascii-allowlist (path prefix per line)."
  exit 1
fi

echo "Committing as: $name <$email>"
