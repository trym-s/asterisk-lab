; Rendered by install.sh from asterisk/pjsip-endpoint.conf.tmpl, once per
; entry in SIP_EXTENSIONS. Output goes to /etc/asterisk/pjsip.d/<ext>.conf.
; Edit the template in the repo, not the rendered files directly.

[${SIP_EXT}]
type=endpoint
context=from-softphones
disallow=all
; Wideband first (Opus/G.722 → 16 kHz+) so STT gets full-band audio.
; Falls back to ulaw/alaw for narrowband endpoints.
allow=opus,g722,ulaw,alaw
auth=${SIP_EXT}
aors=${SIP_EXT}
direct_media=no
; Softphones register from behind NAT (e.g. a host softphone reaching the VM
; across a routed/NATed hop). Trust the packet source over SDP/Contact so
; signaling replies and RTP flow back to where the traffic actually came from.
rtp_symmetric=yes
force_rport=yes
rewrite_contact=yes

[${SIP_EXT}]
type=aor
max_contacts=1
remove_existing=yes
qualify_frequency=60
support_path=yes

[${SIP_EXT}]
type=auth
auth_type=userpass
username=${SIP_EXT}
password=${SIP_EXT_PASSWORD}
